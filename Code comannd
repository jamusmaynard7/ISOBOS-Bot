// Require the necessary discord.js classes
const { Client, GatewayIntentBits } = require('discord.js');

// Create a new client instance and specify intents
const client = new Client({
    intents: [
        GatewayIntentBits.Guilds,           // Required for general guild/server access
        GatewayIntentBits.GuildMembers,    // Required to receive the guildMemberAdd event
        GatewayIntentBits.GuildMessages,   // Required to send messages in guild channels
        GatewayIntentBits.MessageContent   // Required for the bot to read message content (for commands, etc.)
    ]
});

// Bot ready event
client.once('ready', () => {
    console.log('Greeting Bot is online!');
});

// Listen for new member joining a guild
client.on('guildMemberAdd', member => {
    // Specify the channel ID where the welcome message should be sent
    // You can get the channel ID by enabling Developer Mode in Discord settings, right-clicking a channel, and selecting "Copy ID"
    const channelId = 'YOUR_CHANNEL_ID'; 

    // Fetch the channel and send a welcome message
    member.guild.channels.fetch(channelId).then(channel => {
        if (channel) {
            channel.send(`Welcome to the server, <@${member.user.id}>! Please read the rules.`)
                .catch(console.error); // Catch potential errors
        } else {
            console.log(`Channel with ID ${channelId} not found.`);
        }
    }).catch(console.error);
});

